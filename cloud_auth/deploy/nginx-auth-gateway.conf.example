# ZhiShao cloud auth gateway example.
# Before applying, copy the currently working RDK upstream from the existing Nginx config.

upstream zhishao_auth_gateway {
    server 127.0.0.1:9100;
}

upstream zhishao_rdk_monitor {
    # Replace this with the currently verified RDK monitor upstream.
    server 127.0.0.1:5000;
}

server {
    listen 80;
    server_name _;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    location = /auth/verify {
        internal;
        proxy_pass http://zhishao_auth_gateway/auth/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
    }

    location /login {
        proxy_pass http://zhishao_auth_gateway;
    }

    location /logout {
        proxy_pass http://zhishao_auth_gateway;
    }

    location /admin/ {
        auth_request /auth/verify;
        error_page 401 =302 /login;
        proxy_pass http://zhishao_auth_gateway;
    }

    location / {
        auth_request /auth/verify;
        error_page 401 =302 /login;
        proxy_pass http://zhishao_rdk_monitor;
    }
}
