# RDK -> cloud VLM brain address.
# Main deployment:
#   RDK 127.0.0.1:19000
#     -> zhishao-brain-tunnel SSH local forward
#     -> cloud server 127.0.0.1:9000
#     -> DashScope / Qwen-VL
#
# Do not expose cloud port 9000 to the public internet.
ZHISHAO_VLM_BASE_URL=http://127.0.0.1:19000
ZHISHAO_BRAIN_URL_ANALYZE=http://127.0.0.1:19000/analyze
ZHISHAO_BRAIN_URL_ASK=http://127.0.0.1:19000/ask
ZHISHAO_BRAIN_URL_SUMMARIZE=http://127.0.0.1:19000/summarize
ZHISHAO_BRAIN_URL_HEALTH=http://127.0.0.1:19000/health

# Windows VLM is now only a development fallback.
# If you need local Windows testing, start windows_brain/vlm_service_cascade.py
# and override the URLs above to http://<WINDOWS_IP>:9000.

# Public monitor URL exposed by cloud reverse proxy / HTTPS domain.
# Leave empty to show the RDK LAN URL only.
ZHISHAO_PUBLIC_MONITOR_URL=

# Care location shown in assistant replies and weather context.
# Public IP geolocation is disabled by default because mobile hotspots may report a nearby city.
ZHISHAO_CARE_CITY=马鞍山
ZHISHAO_CARE_LOCATION=中国 安徽 马鞍山
ZHISHAO_USE_IP_GEOLOCATION=false

# Feishu bot.
# Put real values in .env on the RDK only. Do not commit real secrets.
FEISHU_WEBHOOK=your_feishu_webhook_url
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
